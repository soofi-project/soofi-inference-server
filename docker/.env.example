# Triton + vLLM + Open WebUI Configuration
# Copy this file to .env and adjust values

#===============================================================================
# Model Configuration
#===============================================================================
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
MODEL_REPOSITORY=../models/model_repository

# HuggingFace Token (optional for Qwen, required for gated models)
HF_TOKEN=your_huggingface_token_here

#===============================================================================
# GPU Settings
#===============================================================================
# Use both GPUs: 0,1 | Single GPU: 0
CUDA_VISIBLE_DEVICES=0
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.90
# Must fit in KV cache! Reduce if "max seq len larger than KV cache" error occurs
MAX_MODEL_LEN=16384

#===============================================================================
# Triton Ports
#===============================================================================
HTTP_PORT=8000
GRPC_PORT=8001
METRICS_PORT=8002

#===============================================================================
# LiteLLM Proxy
#===============================================================================
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-your-secret-key-here

#===============================================================================
# Open WebUI
#===============================================================================
WEBUI_PORT=3000
WEBUI_AUTH=true
WEBUI_NAME=AI Inference Server

#===============================================================================
# Container Images
#===============================================================================
TRITON_IMAGE=nvcr.io/nvidia/tritonserver:24.08-vllm-python-py3
