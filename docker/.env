# vLLM + LiteLLM + Open WebUI — local Docker Compose configuration

# --- Secrets file ---
# Path to a file outside the repo containing secrets. Create it once:
#
#   echo "HF_TOKEN=hf_your_token_here" > ~/.env.secrets
#   echo "LITELLM_MASTER_KEY=sk-your-key" >> ~/.env.secrets
#
ENV_SECRETS_FILE=~/.env.secrets

# Model cache (path relative to docker/ directory)
HF_CACHE_DIR=../models/hf_cache

# Ports
LITELLM_PORT=4000
WEBUI_PORT=3000
