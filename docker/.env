# Triton Inference Server — local Docker Compose configuration

# --- Secrets file ---
# Path to a file outside the repo containing secrets. Create it once:
#
#   echo "HF_TOKEN=hf_your_token_here" > ~/.env.secrets
#   echo "LITELLM_MASTER_KEY=sk-your-key" >> ~/.env.secrets  # remove after T-06-7
#
# HF_TOKEN is required by Triton to download models from HuggingFace.
ENV_SECRETS_FILE=~/.env.secrets

# Container image
TRITON_IMAGE=nvcr.io/nvidia/tritonserver:26.01-vllm-python-py3

# Model (must match models list in ansible/inventory/group_vars/gpu_nodes/vars.yaml)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# GPU
CUDA_VISIBLE_DEVICES=0,1

# Model storage (paths relative to docker/ directory)
MODEL_REPOSITORY=../models/model_repository
HF_CACHE_DIR=../models/hf_cache

# Ports
HTTP_PORT=8000
GRPC_PORT=8001
METRICS_PORT=8002
OPENAI_PORT=9000
LITELLM_PORT=4000
WEBUI_PORT=3000
