# Kubernetes Secrets - COPY TO secrets.yaml AND ADJUST VALUES
# Do NOT commit secrets.yaml to git!
#
# Apply with: kubectl apply -f kubernetes/secrets.yaml
#
# To generate base64 values:
#   echo -n "your-value" | base64

apiVersion: v1
kind: Secret
metadata:
  name: hf-secret
  namespace: triton-inference
type: Opaque
data:
  # echo -n "hf_xxxxxxxxxxxx" | base64
  HF_TOKEN: aGZfeHh4eHh4eHh4eHh4eA==
---
apiVersion: v1
kind: Secret
metadata:
  name: litellm-secret
  namespace: triton-inference
type: Opaque
data:
  # echo -n "sk-your-secret-key" | base64
  master-key: c2steW91ci1zZWNyZXQta2V5
