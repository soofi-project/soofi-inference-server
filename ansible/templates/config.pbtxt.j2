name: "{{ item.triton_name }}"
backend: "vllm"

input [
  {
    name: "text_input"
    data_type: TYPE_STRING
    dims: [ 1 ]
  },
  {
    name: "stream"
    data_type: TYPE_BOOL
    dims: [ 1 ]
    optional: true
  },
  {
    name: "sampling_parameters"
    data_type: TYPE_STRING
    dims: [ 1 ]
    optional: true
  }
]

output [
  {
    name: "text_output"
    data_type: TYPE_STRING
    dims: [ -1 ]
  }
]

instance_group [
  {
    count: 1
{% set pp = item.pipeline_parallel_size | default(pipeline_parallel_size) | int %}
{% set tp = item.tensor_parallel_size | default(tensor_parallel_size) | int %}
{% if pp > 1 or tp > 1 %}
    kind: KIND_MODEL
{% else %}
    kind: KIND_GPU
    gpus: [ {{ item.cuda_visible_devices | default('0') }} ]
{% endif %}
  }
]

