# LiteLLM Proxy Configuration
# Generated by Ansible (stack_deploy.yaml) — do not edit manually on the server.
# Source of truth: ansible/inventory/group_vars/gpu_nodes/vars.yaml

model_list:
{% for model in models %}
  - model_name: {{ model.name }}
    litellm_params:
      model: openai/{{ model.name }}
      api_base: http://vllm-{{ model.name }}:8000/v1
      api_key: "dummy"

{% endfor %}
{% for service in aux_services or [] %}
  - model_name: {{ service.litellm_name }}
    litellm_params:
      model: {{ service.litellm_model }}
      api_base: http://{{ service.name }}:{{ service.container_port }}/v1
      api_key: "dummy"

{% endfor %}
litellm_settings:
  drop_params: true
  set_verbose: false
