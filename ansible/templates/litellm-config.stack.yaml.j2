# LiteLLM Proxy Configuration
# Generated by Ansible (stack_deploy.yaml) — do not edit manually on the server.
# Source of truth: ansible/inventory/group_vars/gpu_nodes/vars.yaml

model_list:
{% for model in active_models %}
  - model_name: {{ model.name }}
    litellm_params:
      model: openai/{{ model.name }}
      api_base: http://vllm-{{ model.name }}:8000/v1
      api_key: "dummy"
      supports_function_calling: true
      supports_tool_choice: true
      max_tokens: 16384

{% endfor %}
{% if stt_service is defined and stt_service.litellm_name is defined %}
  - model_name: {{ stt_service.litellm_name }}
    litellm_params:
      model: {{ stt_service.litellm_model }}
      api_base: http://{{ stt_service.container_name }}:{{ stt_service.container_port }}/v1
      api_key: "dummy"

{% endif %}
{% if tts_service is defined and tts_service.litellm_name is defined %}
  - model_name: {{ tts_service.litellm_name }}
    litellm_params:
      model: {{ tts_service.litellm_model }}
      api_base: http://{{ tts_service.container_name }}:{{ tts_service.container_port }}/v1
      api_key: "dummy"

{% endif %}
{% if tts_service is defined and tts_service.litellm_name_hd is defined %}
  - model_name: {{ tts_service.litellm_name_hd }}
    litellm_params:
      model: {{ tts_service.litellm_model_hd }}
      api_base: http://{{ tts_service.container_name }}:{{ tts_service.container_port }}/v1
      api_key: "dummy"

{% endif %}
general_settings:
  pass_through_endpoints:
{% for model in active_models %}
    - path: "/vllm-metrics/{{ model.name }}"
      target: "http://vllm-{{ model.name }}:8000/metrics"
      headers: {}
{% endfor %}

litellm_settings:
  drop_params: false
  set_verbose: false
  tool_format: openai
  callbacks:
    - prometheus

router_settings:
  enable_auto_tool_choice: true
  fallback_to_default: false
  timeout: 120
