# Triton Inference Server Configuration
# Generated by Ansible — do not edit manually

# Secrets are deployed directly by Ansible — no external secrets file needed on the server
ENV_SECRETS_FILE=/dev/null

# HuggingFace Token (required for model download)
HF_TOKEN={{ hf_token }}

# GPU Settings
CUDA_VISIBLE_DEVICES=0,1

# Model Storage (absolute paths)
MODEL_REPOSITORY={{ deploy_dir }}/models/model_repository
HF_CACHE_DIR={{ deploy_dir }}/models/hf_cache

# OpenAI frontend tokenizer — uses first model in the models list
MODEL_NAME={{ models[0].hf_name if models | length > 0 else '' }}

# Tool call parser for OpenAI frontend (e.g. qwen3_coder, llama3, mistral)
{% if models[0].tool_call_parser is defined %}
TOOL_CALL_PARSER={{ models[0].tool_call_parser }}
{% endif %}

# Triton Ports
HTTP_PORT={{ http_port | default(8000) }}
GRPC_PORT={{ grpc_port | default(8001) }}
METRICS_PORT={{ metrics_port | default(8002) }}
OPENAI_PORT={{ openai_port | default(9000) }}

# LiteLLM Proxy
LITELLM_PORT={{ litellm_port | default(4000) }}
LITELLM_MASTER_KEY={{ litellm_master_key }}

# Open WebUI
WEBUI_PORT={{ webui_port | default(3000) }}
WEBUI_AUTH={{ webui_auth | default('true') }}
WEBUI_NAME={{ webui_name | default('AI Inference Server') }}

# Container Images
TRITON_IMAGE={{ triton_image | default('nvcr.io/nvidia/tritonserver:26.02-vllm-python-py3') }}

