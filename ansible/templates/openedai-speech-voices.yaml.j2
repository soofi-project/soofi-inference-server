# openedai-speech voice_to_speaker.yaml
# Generated by Ansible — do not edit manually on the server.
#
# tts-1    → Piper ONNX (CPU, schnell) — models under /app/piper
# tts-1-hd → Coqui XTTS v2 (GPU) — speakers from image-bundled /app/voices/*.wav
#
# Piper (tts-1):
#   German:  alloy = thorsten-high, echo/fable = thorsten_emotional, nova = kerstin
#   English: onyx, shimmer = lessac-high

tts-1:
  alloy:
    model: piper/de_DE-thorsten-high.onnx
    speaker:
  echo:
    model: piper/de_DE-thorsten_emotional-medium.onnx
    speaker:
  fable:
    model: piper/de_DE-thorsten_emotional-medium.onnx
    speaker:
  nova:
    model: piper/de_DE-kerstin-low.onnx
    speaker:
  onyx:
    model: piper/en_US-lessac-high.onnx
    speaker:
  shimmer:
    model: piper/en_US-lessac-high.onnx
    speaker:

{% if tts_service.xtts_voices is defined %}
tts-1-hd:
{% for v in tts_service.xtts_voices %}
  {{ v.name }}:
    model: xtts_v2.0.2
    speaker: {{ v.speaker_wav }}
    language: {{ v.language }}
{% endfor %}
{% endif %}
