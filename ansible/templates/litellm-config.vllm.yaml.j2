# LiteLLM Proxy Configuration
# Generated by Ansible (vllm_deploy.yaml) — do not edit manually on the server.
# Source of truth: ansible/inventory/group_vars/gpu_nodes/vars.yaml
#
# Each vLLM container is reachable within the Docker network as:
#   http://vllm-<name>:8000/v1

model_list:
{% for model in models %}
  - model_name: {{ model.name }}
    litellm_params:
      model: openai/{{ model.name }}
      api_base: http://vllm-{{ model.name }}:8000/v1
      api_key: "dummy"

{% endfor %}
  # ── Embed / Rerank models (currently on Mac Studio) ───────────────────────
  # - model_name: qwen3-embed-8b
  #   litellm_params:
  #     model: openai/qwen3-embed-8b
  #     api_base: http://mac-studio:7997/v1
  #     api_key: "dummy"

litellm_settings:
  drop_params: true
  set_verbose: false
