# Docker Compose — Inference Stack
# Generated by Ansible (stack_deploy.yaml) — do not edit manually on the server.
# Source of truth: ansible/inventory/group_vars/gpu_nodes/vars.yaml

{# ── Macro: render a service block (STT or TTS) ─────────────────────────── #}
{% macro render_service(service) %}
  # ===========================================================================
  # {{ service.container_name }}
  # ===========================================================================
  {{ service.container_name }}:
    image: {{ service.image }}
    container_name: {{ service.container_name }}
    restart: unless-stopped
    init: true

{% if service.gpu_devices is defined %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: {{ service.gpu_devices | tojson }}
              capabilities: [gpu]

{% endif %}
    ports:
      - "{{ service.internal_port }}:{{ service.container_port }}"

{% if service.volumes is defined %}
    volumes:
{% for vol in service.volumes %}
      - {{ vol }}
{% endfor %}

{% endif %}
{% if service.environment is defined %}
    environment:
{% for env in service.environment %}
      - {{ env }}
{% endfor %}

{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ service.container_port }}{{ service.healthcheck_path | default('/health') }}"]
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 120s

    networks:
      - inference-net
{% endmacro %}

services:
{% for model in active_models %}
{% set cfg = vllm_defaults.config | combine(model.vllm | default({}), recursive=True) %}
{% set parser = parser_profiles.get(model.parser_profile, {}) if model.parser_profile is defined else {} %}
  # ===========================================================================
  # vLLM: {{ model.name }}  ({{ model.hf_name }})
  # ===========================================================================
  vllm-{{ model.name }}:
    image: {{ model.repository | default(vllm_defaults.repository) }}:{{ model.tag | default(vllm_defaults.tag) }}
    container_name: vllm-{{ model.name }}
    restart: unless-stopped

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: {{ model.gpu_ids | tojson }}
              capabilities: [gpu]

    environment:
      - HUGGING_FACE_HUB_TOKEN={{ hf_token }}
      - HF_TOKEN={{ hf_token }}
      - LD_LIBRARY_PATH=/lib/x86_64-linux-gnu:/usr/local/cuda/lib64

    volumes:
      - {{ deploy_dir }}/models/hf_cache:/root/.cache/huggingface

    command:
      - "--model"
      - "{{ model.hf_name }}"
      - "--served-model-name"
      - "{{ model.name }}"
      - "--tensor-parallel-size"
      - "{{ cfg.tensor_parallel_size }}"
      - "--gpu-memory-utilization"
      - "{{ cfg.gpu_memory_utilization }}"
      - "--max-model-len"
      - "{{ cfg.max_model_len }}"
      - "--dtype"
      - "{{ cfg.dtype }}"
{% if cfg.enable_prefix_caching | default(false) %}
      - "--enable-prefix-caching"
{% endif %}
{% if cfg.enable_chunked_prefill | default(false) %}
      - "--enable-chunked-prefill"
{% endif %}
{% if parser.enable_auto_tool_choice | default(false) %}
      - "--enable-auto-tool-choice"
{% endif %}
{% if parser.tool_call_parser is defined %}
      - "--tool-call-parser"
      - {{ parser.tool_call_parser | tojson }}
{% endif %}
{% if parser.reasoning_parser is defined %}
      - "--reasoning-parser"
      - {{ parser.reasoning_parser | tojson }}
{% endif %}
{% if cfg.max_num_seqs is defined %}
      - "--max-num-seqs"
      - "{{ cfg.max_num_seqs }}"
{% endif %}
{% if cfg.max_num_batched_tokens is defined %}
      - "--max-num-batched-tokens"
      - "{{ cfg.max_num_batched_tokens }}"
{% endif %}
{% if cfg.swap_space is defined %}
      - "--swap-space"
      - "{{ cfg.swap_space }}"
{% endif %}
{% if cfg.kv_cache_dtype is defined %}
      - "--kv-cache-dtype"
      - "{{ cfg.kv_cache_dtype }}"
{% endif %}
{% if cfg.pipeline_parallel_size is defined %}
      - "--pipeline-parallel-size"
      - "{{ cfg.pipeline_parallel_size }}"
{% endif %}
{% if cfg.data_parallel_size is defined %}
      - "--data-parallel-size"
      - "{{ cfg.data_parallel_size }}"
{% endif %}
{% if cfg.attention_backend is defined %}
      - "--attention-backend"
      - {{ cfg.attention_backend | tojson }}
{% endif %}
{% if cfg.mamba_ssm_cache_dtype is defined %}
      - "--mamba-ssm-cache-dtype"
      - {{ cfg.mamba_ssm_cache_dtype | tojson }}
{% endif %}
{% if cfg.max_cudagraph_capture_size is defined %}
      - "--max-cudagraph-capture-size"
      - "{{ cfg.max_cudagraph_capture_size }}"
{% endif %}
{% if cfg.language_model_only | default(false) %}
      - "--language-model-only"
{% endif %}
{% if cfg.calculate_kv_scales | default(false) %}
      - "--calculate-kv-scales"
{% endif %}
{% if cfg.trust_remote_code | default(false) %}
      - "--trust-remote-code"
{% endif %}
{% if cfg.async_scheduling | default(false) %}
      - "--async-scheduling"
{% endif %}
{% if cfg.enable_expert_parallel | default(false) %}
      - "--enable-expert-parallel"
{% endif %}
{% for arg in model.extra_args | default([]) %}
      - {{ arg | tojson }}
{% endfor %}

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 40
      start_period: 300s

    shm_size: '16gb'

    ulimits:
      memlock:
        soft: -1
        hard: -1
      stack:
        soft: 67108864
        hard: 67108864

    networks:
      - inference-net

{% endfor %}
{% if stt_service is defined %}
{{ render_service(stt_service) }}
{% endif %}
{% if tts_service is defined %}
{{ render_service(tts_service) }}
{% endif %}

  # ===========================================================================
  # LiteLLM Proxy — single external API endpoint for all models and services
  # ===========================================================================
  litellm:
    image: {{ litellm_image }}
    container_name: litellm-proxy
    restart: unless-stopped

    ports:
      - "{{ litellm_port | default(4000) }}:4000"

    volumes:
      - {{ deploy_dir }}/docker/litellm-config.yaml:/app/config.yaml

    # Force container recreation when model list changes — Compose does not
    # detect changes to volume-mounted config files, only to the service definition.
    environment:
      - LITELLM_MODELS={{ models | map(attribute='name') | list | join(',') }}

    command: ["--config", "/app/config.yaml", "--port", "4000"]

    depends_on:
{% for model in active_models %}
      vllm-{{ model.name }}:
        condition: service_healthy
{% endfor %}
{% if stt_service is defined %}
      {{ stt_service.container_name }}:
        condition: service_healthy
{% endif %}
{% if tts_service is defined %}
      {{ tts_service.container_name }}:
        condition: service_healthy
{% endif %}

    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:4000/health/liveliness')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

    networks:
      - inference-net

  # ===========================================================================
  # Open WebUI — Chat Interface
  # ===========================================================================
  open-webui:
    image: {{ webui_image }}
    container_name: open-webui
    restart: unless-stopped

    ports:
      - "{{ webui_port | default(3000) }}:8080"

    volumes:
      - open-webui-data:/app/backend/data

    environment:
      - OPENAI_API_BASE_URLS=http://litellm:4000/v1
      - OPENAI_API_KEYS=dummy
      - WEBUI_AUTH={{ webui_auth | default('true') }}
      - WEBUI_NAME={{ webui_name | default('AI Inference Server') }}
      - ENABLE_OLLAMA_API=false
      - OFFLINE_MODE=true
      - RAG_EMBEDDING_MODEL_AUTO_UPDATE=false
      - RAG_RERANKING_MODEL_AUTO_UPDATE=false

    depends_on:
      litellm:
        condition: service_healthy

    networks:
      - inference-net

volumes:
  open-webui-data:
    name: open_webui_data

networks:
  inference-net:
    name: inference-network
    driver: bridge
