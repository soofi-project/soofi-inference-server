# Docker Compose — Inference Stack
# Generated by Ansible (stack_deploy.yaml) — do not edit manually on the server.
# Source of truth: ansible/inventory/group_vars/gpu_nodes/vars.yaml

services:
{% for model in models %}
  # ===========================================================================
  # vLLM: {{ model.name }}  ({{ model.hf_name }})
  # ===========================================================================
  vllm-{{ model.name }}:
    image: {{ model.repository | default(vllm_repository) }}:{{ model.tag | default(vllm_tag) }}
    container_name: vllm-{{ model.name }}
    restart: unless-stopped

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              device_ids: {{ model.gpu_ids | tojson }}
              capabilities: [gpu]

    environment:
      - HUGGING_FACE_HUB_TOKEN={{ hf_token }}
      - HF_TOKEN={{ hf_token }}
      - LD_LIBRARY_PATH=/lib/x86_64-linux-gnu:/usr/local/cuda/lib64

    volumes:
      - {{ deploy_dir }}/models/hf_cache:/root/.cache/huggingface

    ports:
      - "{{ model.internal_port }}:8000"

    command:
      - "--model"
      - "{{ model.hf_name }}"
      - "--tensor-parallel-size"
      - "{{ model.vllmConfig.tensorParallelSize | default(1) }}"
      - "--gpu-memory-utilization"
      - "{{ model.vllmConfig.gpuMemoryUtilization | default(0.92) }}"
      - "--max-model-len"
      - "{{ model.vllmConfig.maxModelLen | default(32768) }}"
      - "--dtype"
      - "{{ model.vllmConfig.dtype | default('auto') }}"
{% if model.vllmConfig.enablePrefixCaching | default(false) %}
      - "--enable-prefix-caching"
{% endif %}
{% if model.vllmConfig.enableChunkedPrefill | default(false) %}
      - "--enable-chunked-prefill"
{% endif %}
{% for arg in model.vllmConfig.extraArgs | default([]) %}
      - "{{ arg }}"
{% endfor %}

    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 40
      start_period: 300s

    shm_size: '16gb'

    ulimits:
      memlock:
        soft: -1
        hard: -1
      stack:
        soft: 67108864
        hard: 67108864

    networks:
      - inference-net

{% endfor %}
{% for service in aux_services | default([]) %}
  # ===========================================================================
  # Auxiliary: {{ service.name }}
  # ===========================================================================
  {{ service.name }}:
    image: {{ service.image }}
    container_name: {{ service.name }}
    restart: unless-stopped

    ports:
      - "{{ service.internal_port }}:{{ service.container_port }}"

{% if service.environment is defined %}
    environment:
{% for env in service.environment %}
      - {{ env }}
{% endfor %}

{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ service.container_port }}{{ service.healthcheck_path | default('/health') }}"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s

    networks:
      - inference-net

{% endfor %}
  # ===========================================================================
  # LiteLLM Proxy — single external API endpoint for all models and services
  # ===========================================================================
  litellm:
    image: ghcr.io/berriai/litellm:main-latest
    container_name: litellm-proxy
    restart: unless-stopped

    ports:
      - "{{ litellm_port | default(4000) }}:4000"

    volumes:
      - {{ deploy_dir }}/docker/litellm-config.yaml:/app/config.yaml

    command: ["--config", "/app/config.yaml", "--port", "4000"]

    depends_on:
{% for model in models %}
      vllm-{{ model.name }}:
        condition: service_healthy
{% endfor %}
{% for service in aux_services | default([]) %}
      {{ service.name }}:
        condition: service_healthy
{% endfor %}

    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:4000/health/liveliness')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

    networks:
      - inference-net

  # ===========================================================================
  # Open WebUI — Chat Interface
  # ===========================================================================
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: unless-stopped

    ports:
      - "{{ webui_port | default(3000) }}:8080"

    volumes:
      - open-webui-data:/app/backend/data

    environment:
      - OPENAI_API_BASE_URLS=http://litellm:4000/v1
      - OPENAI_API_KEYS=dummy
      - WEBUI_AUTH={{ webui_auth | default('true') }}
      - WEBUI_NAME={{ webui_name | default('AI Inference Server') }}
      - ENABLE_OLLAMA_API=false

    depends_on:
      litellm:
        condition: service_healthy

    networks:
      - inference-net

volumes:
  open-webui-data:
    name: open_webui_data

networks:
  inference-net:
    name: inference-network
    driver: bridge
